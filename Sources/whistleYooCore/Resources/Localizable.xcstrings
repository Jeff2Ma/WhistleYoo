    "core.a_global_whistle_installation_was_not_found_run_npm_install_g_whistle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A global Whistle installation was not found. Run npm install -g whistle."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到全局 Whistle，请执行 npm install -g whistle"
          }
        }
      },
      "comment": "中文：未找到全局 Whistle，请执行 npm install -g whistle"
    },
    "core.a_matching_fingerprint_was_found_in_the_login_keychain": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A matching fingerprint was found in the login keychain"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录钥匙串中已找到匹配指纹"
          }
        }
      },
      "comment": "中文：登录钥匙串中已找到匹配指纹"
    },
    "core.after_setting_the_proxy_scan_to_download_the_certificate_on_ios_install": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After setting the proxy, scan to download the certificate. On iOS, install it in Settings and enable full trust."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置代理后扫码下载证书。iOS 还需要在系统设置中安装并开启完全信任。"
          }
        }
      },
      "comment": "中文：设置代理后扫码下载证书。iOS 还需要在系统设置中安装并开启完全信任。"
    },
    "core.an_incompatible_whistleyoo_configuration_file_cannot_be_written": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An incompatible WhistleYoo configuration file cannot be written"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不能写入版本不兼容的 WhistleYoo 配置文件"
          }
        }
      },
      "comment": "中文：不能写入版本不兼容的 WhistleYoo 配置文件"
    },
    "core.apply_the_enabled_state_when_saving": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply the enabled state when saving"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存时应用启用状态"
          }
        }
      },
      "comment": "中文：保存时应用启用状态"
    },
    "core.built_in_compatibility_rules_read_only": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Built-in compatibility rules · Read-only"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "内置兼容性规则 · 只读"
          }
        }
      },
      "comment": "中文：内置兼容性规则 · 只读"
    },
    "core.built_in_rule_read_only": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Built-in rule, read-only"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "内置规则，不可修改"
          }
        }
      },
      "comment": "中文：内置规则，不可修改"
    },
    "core.changing_active_ports_safely_restarts_the_proxy_engine_automatically": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Changing active ports safely restarts the proxy engine automatically."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "修改运行中的端口会自动安全重启代理引擎。"
          }
        }
      },
      "comment": "中文：修改运行中的端口会自动安全重启代理引擎。"
    },
    "core.command_timed_out_value": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Command timed out: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "命令执行超时：%@"
          }
        }
      },
      "comment": "中文：命令执行超时：%@"
    },
    "core.disabling_the_system_proxy_did_not_complete": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disabling the system proxy did not complete"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统代理关闭未完成"
          }
        }
      },
      "comment": "中文：系统代理关闭未完成"
    },
    "core.do_not_decrypt_and_hide_common_domains_for_apple_icloud_jetbrains_and_ot": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Do not decrypt and hide common domains for Apple, iCloud, JetBrains, and other apps to reduce certificate issues and capture noise."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不解密并隐藏 Apple、iCloud、JetBrains 等常用软件域名，减少证书兼容问题和抓包噪音。"
          }
        }
      },
      "comment": "中文：不解密并隐藏 Apple、iCloud、JetBrains 等常用软件域名，减少证书兼容问题和抓包噪音。"
    },
    "core.enabling_the_system_proxy_failed_and_automatic_restoration_did_not_compl": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enabling the system proxy failed, and automatic restoration did not complete: %@; %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统代理启用失败，且自动恢复未完成：%@；%@"
          }
        }
      },
      "comment": "中文：系统代理启用失败，且自动恢复未完成：%@；%@"
    },
    "core.https_inspection_requires_installing_and_trusting_the_root_certificate": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTPS inspection requires installing and trusting the root certificate"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTPS 调试需要安装并信任根证书"
          }
        }
      },
      "comment": "中文：HTTPS 调试需要安装并信任根证书"
    },
    "core.in_the_http_proxy_settings_for_the_phone_s_current_wi_fi_network_choose": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In the HTTP proxy settings for the phone's current Wi-Fi network, choose Manual and enter:"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在手机当前 Wi-Fi 的 HTTP 代理设置中选择“手动”，然后填写："
          }
        }
      },
      "comment": "中文：在手机当前 Wi-Fi 的 HTTP 代理设置中选择“手动”，然后填写："
    },
    "core.in_the_mobile_device_s_wi_fi_http_proxy_settings_choose_manual_enter_the": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In the mobile device's Wi-Fi HTTP proxy settings, choose Manual, enter the IP address above as the server, and use port %@. On iOS, confirm installation and trust in Settings after downloading the certificate."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在手机 Wi-Fi 的 HTTP 代理中选择“手动”，服务器填写上方 IP，端口填写 %@。iOS 下载证书后还需在系统设置中确认安装与信任。"
          }
        }
      },
      "comment": "中文：在手机 Wi-Fi 的 HTTP 代理中选择“手动”，服务器填写上方 IP，端口填写 %@。iOS 下载证书后还需在系统设置中确认安装与信任。"
    },
